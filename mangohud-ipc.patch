new file mode 100644
index 0000000..b68669a
--- /dev/null
+++ b/src/ipc.h
@@ -0,0 +1,30 @@
+#pragma once
+#include <stdint.h>
+
+struct MangoHudIPCData {
+    uint64_t update_count;
+    double fps;
+    double fps_average;
+    double fps_1pct;
+    double fps_01pct;
+    double frametime;
+    double gpu_load;
+    double gpu_temp;
+    double gpu_power;
+    double gpu_voltage;
+    double gpu_core_clock;
+    double gpu_mem_clock;
+    double cpu_load;
+    double cpu_temp;
+    double cpu_power;
+    double cpu_mhz;
+    double gpu_vram_used;
+    double proc_vram;
+    double ram_used;
+    double process_rss;
+    uint64_t core_count;
+    double core_load[128];
+};
+
+void ipc_init();
+void ipc_update(struct swapchain_stats& sw_stats, float fps_average, float fps_1pct, float fps_01pct, float frametime_ms);
