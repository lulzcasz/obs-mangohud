diff --git a/src/ipc.cpp b/src/ipc.cpp
new file mode 100644
index 0000000..36da49b
--- /dev/null
+++ b/src/ipc.cpp
@@ -0,0 +1,77 @@
+#include "ipc.h"
+#include "cpu.h"
+#include "gpu.h"
+#include "logging.h"
+#include "overlay.h"
+#include <sys/mman.h>
+#include <fcntl.h>
+#include <unistd.h>
+
+static MangoHudIPCData* shared_telemetry = nullptr;
+static bool shm_initialized = false;
+
+void ipc_init() {
+    if (shm_initialized) return;
+
+    int shm_fd = shm_open("/MangoHudTelemetry", O_CREAT | O_RDWR, 0666);
+    if (shm_fd >= 0) {
+        ftruncate(shm_fd, sizeof(MangoHudIPCData));
+        shared_telemetry = (MangoHudIPCData*)mmap(0, sizeof(MangoHudIPCData), PROT_READ | PROT_WRITE, MAP_SHARED, shm_fd, 0);
+        if (shared_telemetry == MAP_FAILED) {
+            shared_telemetry = nullptr;
+        }
+    }
+    shm_initialized = true;
+}
+
+void ipc_update(struct swapchain_stats& sw_stats, float fps_average, float fps_1pct, float fps_01pct, float frametime_ms) {
+    if (!shm_initialized) {
+        ipc_init();
+    }
+
+    if (!shared_telemetry) return;
+
+    double gpu_voltage = 0.0, proc_vram = 0.0;
+    if (gpus && gpus->active_gpu()) {
+        gpu_voltage = (double)gpus->active_gpu()->metrics.voltage;
+        proc_vram = (double)gpus->active_gpu()->metrics.proc_vram_used;
+    }
+
+    const auto& core_data = cpuStats.GetCPUData();
+    uint64_t cores = core_data.size();
+    if (cores > 128) cores = 128;
+
+    shared_telemetry->update_count++;
+    __atomic_thread_fence(__ATOMIC_RELEASE); 
+
+    shared_telemetry->fps = (double)sw_stats.fps;
+    shared_telemetry->fps_average = (double)fps_average;
+    shared_telemetry->fps_1pct = (double)fps_1pct;
+    shared_telemetry->fps_01pct = (double)fps_01pct;
+    shared_telemetry->frametime = (double)frametime_ms;
+    
+    shared_telemetry->gpu_load = (double)currentLogData.gpu_load;
+    shared_telemetry->gpu_temp = (double)currentLogData.gpu_temp;
+    shared_telemetry->gpu_power = (double)currentLogData.gpu_power;
+    shared_telemetry->gpu_voltage = gpu_voltage;
+    shared_telemetry->gpu_core_clock = (double)currentLogData.gpu_core_clock;
+    shared_telemetry->gpu_mem_clock = (double)currentLogData.gpu_mem_clock;
+    
+    shared_telemetry->cpu_load = (double)currentLogData.cpu_load;
+    shared_telemetry->cpu_temp = (double)currentLogData.cpu_temp;
+    shared_telemetry->cpu_power = (double)currentLogData.cpu_power;
+    shared_telemetry->cpu_mhz = (double)currentLogData.cpu_mhz;
+    
+    shared_telemetry->gpu_vram_used = (double)currentLogData.gpu_vram_used;
+    shared_telemetry->proc_vram = proc_vram;
+    shared_telemetry->ram_used = (double)currentLogData.ram_used;
+    shared_telemetry->process_rss = (double)currentLogData.process_rss;
+
+    shared_telemetry->core_count = cores;
+    for (uint64_t i = 0; i < cores; i++) {
+        shared_telemetry->core_load[i] = (double)core_data[i].percent;
+    }
+
+    __atomic_thread_fence(__ATOMIC_RELEASE);
+    shared_telemetry->update_count++; 
+}
