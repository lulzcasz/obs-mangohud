diff --git a/src/shm.cpp b/src/shm.cpp
new file mode 100644
index 0000000..5665fbc
--- /dev/null
+++ b/src/shm.cpp
@@ -0,0 +1,54 @@
+#include <iostream>
+#include <sys/mman.h>
+#include <fcntl.h>
+#include <unistd.h>
+#include "shm.h"
+
+static MangoHudSHM* data = nullptr;
+static bool initialized = false;
+
+__attribute__((destructor))
+static void cleanup() {
+    if (data) {
+        munmap(data, sizeof(MangoHudSHM));
+        data = nullptr;
+    }
+
+    shm_unlink("/MangoHud");
+}
+
+static void init() {
+    if (initialized) return;
+
+    int fd = shm_open("/MangoHud", O_CREAT | O_RDWR, 0666);
+    if (fd >= 0) {
+        ftruncate(fd, sizeof(MangoHudSHM));
+
+        data = (MangoHudSHM*)mmap(0, sizeof(MangoHudSHM), PROT_READ | PROT_WRITE, MAP_SHARED, fd, 0);
+        
+        if (data == MAP_FAILED) {
+            data = nullptr;
+        }
+
+        close(fd);
+    }
+    initialized = true;
+}
+
+void shm_update(const MangoHudMetrics& metrics) {
+    if (!initialized) {
+        init();
+    }
+
+    if (!data) return;
+
+    data->update_count++;
+
+    __atomic_thread_fence(__ATOMIC_RELEASE); 
+
+    data->metrics = metrics;
+
+    __atomic_thread_fence(__ATOMIC_RELEASE); 
+
+    data->update_count++; 
+}
diff --git a/src/shm.h b/src/shm.h
new file mode 100644
index 0000000..3ede287
--- /dev/null
+++ b/src/shm.h
@@ -0,0 +1,18 @@
+#pragma once
+#include <stdint.h>
+
+struct MangoHudMetrics {
+    float fps;
+    float frametime;
+    double min_frametime;
+    double max_frametime;
+    float cpu_percent;
+    int32_t gpu_load;
+};
+
+struct MangoHudSHM {
+    uint64_t update_count;
+    MangoHudMetrics metrics;
+};
+
+void shm_update(const MangoHudMetrics& metrics);
