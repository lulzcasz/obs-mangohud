diff --git a/src/shm.cpp b/src/shm.cpp
new file mode 100644
index 0000000..ca81070
--- /dev/null
+++ b/src/shm.cpp
@@ -0,0 +1,52 @@
+#include <iostream>
+#include <sys/mman.h>
+#include <fcntl.h>
+#include <unistd.h>
+#include <cstring>
+#include "shm.h"
+
+static MangoHudSHM* data = nullptr;
+static bool initialized = false;
+
+__attribute__((destructor))
+static void cleanup() {
+    if (data) {
+        munmap(data, sizeof(MangoHudSHM));
+        data = nullptr;
+    }
+    shm_unlink("/MangoHud");
+}
+
+static void init() {
+    if (initialized) return;
+
+    int fd = shm_open("/MangoHud", O_CREAT | O_RDWR, 0666);
+    if (fd >= 0) {
+        ftruncate(fd, sizeof(MangoHudSHM));
+        data = (MangoHudSHM*)mmap(0, sizeof(MangoHudSHM), PROT_READ | PROT_WRITE, MAP_SHARED, fd, 0);
+        
+        if (data == MAP_FAILED) {
+            data = nullptr;
+        }
+        close(fd);
+    }
+    initialized = true;
+}
+
+void shm_update(const MangoHudSHM& shm_data) {
+    if (!initialized) {
+        init();
+    }
+
+    if (!data) return;
+
+    data->update_count++;
+    __atomic_thread_fence(__ATOMIC_RELEASE);
+
+    memcpy(data->param_enabled, shm_data.param_enabled, sizeof(bool) * PARAM_ENABLED_MAX);
+    
+    data->metrics = shm_data.metrics;
+
+    __atomic_thread_fence(__ATOMIC_RELEASE); 
+    data->update_count++; 
+}
diff --git a/src/shm.h b/src/shm.h
new file mode 100644
index 0000000..c160d2b
--- /dev/null
+++ b/src/shm.h
@@ -0,0 +1,26 @@
+#pragma once
+#include <stdint.h>
+#include <stdbool.h>
+
+typedef enum {
+    PARAM_GPU_USAGE,
+    PARAM_CPU_USAGE,
+    PARAM_ENABLED_MAX
+} MetricFlag;
+
+struct MangoHudMetrics {
+    float fps;
+    float frametime;
+    double min_frametime;
+    double max_frametime;
+    float cpu_percent;
+    int32_t gpu_load;
+};
+
+struct MangoHudSHM {
+    uint64_t update_count;
+    bool param_enabled[PARAM_ENABLED_MAX];
+    MangoHudMetrics metrics;
+};
+
+void shm_update(const MangoHudSHM& shm_data);
